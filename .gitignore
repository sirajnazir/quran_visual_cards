# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Environment
.env
.env.*
!.env.example
venv/
.venv/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
server.log

